  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#587088",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#00B850"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#FFD300"
      }
    },
    {
      "scope": ["constant.language", "constant.character"],
      "settings": {
        "foreground": "#EE7C0E"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#EE7C0E"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.language"],
      "settings": {
        "foreground": "#d8dce8"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#d8dce8"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#d8dce8"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9B70D8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#F3A9BB"
      }
    },
    {
      "scope": ["keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical", "keyword.operator.comparison", "keyword.operator.ternary"],
      "settings": {
        "foreground": "#F3A9BB"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": {
        "foreground": "#9B70D8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.type.primitive"],
      "settings": {
        "foreground": "#9B70D8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#EE7C0E"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#EE7C0E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#0098D4"
      }
    },
    {
      "scope": ["entity.name.function.method", "meta.function-call"],
      "settings": {
        "foreground": "#0098D4"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#00A4A7"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#0098D4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#708098"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#00A4A7"
      }
    },
    {
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#00A4A7"
      }
    },
    {
      "scope": ["entity.name.tag.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "#0098D4"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color.rgb-value.css"],
      "settings": {
        "foreground": "#EE7C0E"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#FFD300"
      }
    },
    {
      "scope": ["entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": {
        "foreground": "#00A4A7"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading.setext"],
      "settings": {
        "foreground": "#9B70D8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#EE7C0E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#F3A9BB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#00B850"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#0098D4"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#00B850"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#E32017"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#0098D4"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#F3A9BB"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#a8b0c0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.separator"],
      "settings": {
        "foreground": "#708098"
      }
    },
    {
      "scope": ["meta.diff.header"],
      "settings": {
        "foreground": "#0098D4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#E32017"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#708098",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#EE7C0E",
    "class": "#EE7C0E",
    "enum": "#EE7C0E",
    "interface": { "foreground": "#EE7C0E", "fontStyle": "italic" },
    "struct": "#EE7C0E",
    "typeParameter": { "foreground": "#EE7C0E", "fontStyle": "italic" },
    "parameter": "#d8dce8",
    "variable": "#d8dce8",
    "property": "#d8dce8",
    "enumMember": "#EE7C0E",
    "decorator": "#EE7C0E",
    "function": "#0098D4",
    "method": "#0098D4",
    "macro": "#00A4A7",
    "namespace": "#d8dce8",
    "keyword": { "foreground": "#9B70D8", "fontStyle": "italic" },
    "comment": { "foreground": "#587088", "fontStyle": "italic" },
    "string": "#00B850",
    "number": "#FFD300",
    "operator": "#F3A9BB",
    "variable.readonly": "#d8dce8",
    "property.readonly": { "foreground": "#d8dce8", "fontStyle": "italic" },
    "function.defaultLibrary": { "foreground": "#0098D4", "fontStyle": "italic" },
    "variable.defaultLibrary": { "foreground": "#d8dce8", "fontStyle": "italic" }
  }
}
