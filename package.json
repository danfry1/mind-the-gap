{
  "name": "mind-the-gap",
  "version": "0.1.0",
  "description": "A vibrant dark color theme inspired by the London Underground tube map",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danfry1/mind-the-gap.git"
  },
  "homepage": "https://github.com/danfry1/mind-the-gap",
  "bugs": {
