# Auto-generated from palette.json — do not edit manually
# Run `bun run generate` to regenerate
#
# Mind the Gap — tmux theme
# https://github.com/danfry1/mind-the-gap

set -ga terminal-overrides ",*:RGB"

set -g status-style "bg={{backgrounds.mantle}},fg={{foregrounds.subtext}}"
set -g status-left-length 40
set -g status-right-length 40
set -g status-left "#{?client_prefix,#[fg={{backgrounds.crust}}#,bg={{accents.hammersmith}}#,bold] PREFIX ,#[fg={{backgrounds.crust}},bg={{accents.elizabeth}},bold] #{session_name} }#[fg=default,bg={{backgrounds.mantle}},nobold] "
set -g status-right "#[fg={{foregrounds.overlay}}] %H:%M #[fg={{foregrounds.overlay}}]│ #[fg={{foregrounds.overlay}}]#{host_short} "

set -g window-status-format "#[fg={{foregrounds.overlay}},bg={{backgrounds.mantle}}] #{window_index}:#{window_name} "
set -g window-status-current-format "#[fg={{foregrounds.text}},bg={{backgrounds.surface0}},bold] #{window_index}:#{window_name} "
set -g window-status-separator ""

set -g pane-border-style "fg={{backgrounds.surface1}}"
set -g pane-active-border-style "fg={{accents.elizabeth}}"

set -g mode-style "fg={{backgrounds.crust}},bg={{accents.elizabeth}}"

set -g mesdistrict-style "fg={{foregrounds.text}},bg={{backgrounds.surface0}}"
set -g mesdistrict-command-style "fg={{foregrounds.text}},bg={{backgrounds.surface0}}"

set -g clock-mode-colour "{{accents.elizabeth}}"

set -g copy-mode-match-style "fg={{backgrounds.crust}},bg={{accents.circle}}"
set -g copy-mode-current-match-style "fg={{backgrounds.crust}},bg={{accents.overground}}"
