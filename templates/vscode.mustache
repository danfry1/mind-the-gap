  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "{{foregrounds.comment}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "{{accents.district}}"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "{{accents.circle}}"
      }
    },
    {
      "scope": ["constant.language", "constant.character"],
      "settings": {
        "foreground": "{{accents.overground}}"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "{{accents.overground}}"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.language"],
      "settings": {
        "foreground": "{{foregrounds.text}}"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "{{foregrounds.text}}"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "{{foregrounds.text}}"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "{{accents.elizabeth}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "{{accents.hammersmith}}"
      }
    },
    {
      "scope": ["keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical", "keyword.operator.comparison", "keyword.operator.ternary"],
      "settings": {
        "foreground": "{{accents.hammersmith}}"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": {
        "foreground": "{{accents.elizabeth}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.type.primitive"],
      "settings": {
        "foreground": "{{accents.elizabeth}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "{{accents.overground}}"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "{{accents.overground}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "{{accents.victoria}}"
      }
    },
    {
      "scope": ["entity.name.function.method", "meta.function-call"],
      "settings": {
        "foreground": "{{accents.victoria}}"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "{{accents.dlr}}"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "{{accents.victoria}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "{{foregrounds.overlay}}"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "{{accents.dlr}}"
      }
    },
    {
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "{{accents.dlr}}"
      }
    },
    {
      "scope": ["entity.name.tag.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "{{accents.victoria}}"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color.rgb-value.css"],
      "settings": {
        "foreground": "{{accents.overground}}"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "{{accents.circle}}"
      }
    },
    {
      "scope": ["entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": {
        "foreground": "{{accents.dlr}}"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading.setext"],
      "settings": {
        "foreground": "{{accents.elizabeth}}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "{{accents.overground}}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "{{accents.hammersmith}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "{{accents.district}}"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "{{accents.victoria}}"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "{{accents.district}}"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "{{accents.central}}"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "{{accents.victoria}}"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "{{accents.hammersmith}}"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "{{foregrounds.subtext}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.separator"],
      "settings": {
        "foreground": "{{foregrounds.overlay}}"
      }
    },
    {
      "scope": ["meta.diff.header"],
      "settings": {
        "foreground": "{{accents.victoria}}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "{{accents.central}}"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "{{foregrounds.overlay}}",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "{{accents.overground}}",
    "class": "{{accents.overground}}",
    "enum": "{{accents.overground}}",
    "interface": { "foreground": "{{accents.overground}}", "fontStyle": "italic" },
    "struct": "{{accents.overground}}",
    "typeParameter": { "foreground": "{{accents.overground}}", "fontStyle": "italic" },
    "parameter": "{{foregrounds.text}}",
    "variable": "{{foregrounds.text}}",
    "property": "{{foregrounds.text}}",
    "enumMember": "{{accents.overground}}",
    "decorator": "{{accents.overground}}",
    "function": "{{accents.victoria}}",
    "method": "{{accents.victoria}}",
    "macro": "{{accents.dlr}}",
    "namespace": "{{foregrounds.text}}",
    "keyword": { "foreground": "{{accents.elizabeth}}", "fontStyle": "italic" },
    "comment": { "foreground": "{{foregrounds.comment}}", "fontStyle": "italic" },
    "string": "{{accents.district}}",
    "number": "{{accents.circle}}",
    "operator": "{{accents.hammersmith}}",
    "variable.readonly": "{{foregrounds.text}}",
    "property.readonly": { "foreground": "{{foregrounds.text}}", "fontStyle": "italic" },
    "function.defaultLibrary": { "foreground": "{{accents.victoria}}", "fontStyle": "italic" },
    "variable.defaultLibrary": { "foreground": "{{foregrounds.text}}", "fontStyle": "italic" }
  }
}
